# WhatsApp Course Bot Configuration
# Copy this file to .env and configure your settings

# ============================================
# REQUIRED: WhatsApp Chat Configuration
# ============================================

# WhatsApp Group ID or Contact ID where courses will be posted
# 
# For Groups: Format is 1234567890@g.us
# For Contacts: Format is 1234567890@s.whatsapp.net
# 
# How to get this:
# 1. Run the bot first time (leave this empty)
# 2. Scan QR code with WhatsApp
# 3. Check the logs - bot will list all your groups
# 4. Copy the ID of your target group/contact
# 5. Paste it here and restart the bot
#
# Example: WHATSAPP_CHAT_ID=120363123456789012@g.us
WHATSAPP_CHAT_ID=

# ============================================
# OPTIONAL: Bot Behavior
# ============================================

# How often to check for new courses (in seconds)
# Default: 180 (3 minutes)
# Recommended: 180-300 (3-5 minutes)
# Don't set too low to avoid rate limiting
CHECK_INTERVAL=180

# ============================================
# ADMIN CONFIGURATION
# ============================================

# Owner phone numbers (comma-separated, with country code, no + or spaces)
# Owners have full permissions regardless of group admin status
# Group admins are automatically detected and have permissions in their groups
# Example: OWNER_NUMBERS=918830285258,919876543210
OWNER_NUMBERS=

#

# ============================================
# NOTES
# ============================================
# 
# - Keep this file private (it's in .gitignore)
# - Don't share your chat IDs publicly
# - The bot will auto-create posted_courses.db
# - Session data is stored in auth_info_baileys/
# - Check bot.log for detailed logs
# - Group admins are auto-detected (no manual configuration needed)
#
